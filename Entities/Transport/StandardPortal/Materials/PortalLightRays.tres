[gd_resource type="ShaderMaterial" format=3 uid="uid://byhavk6dt3tp3"]

[sub_resource type="Shader" id="Shader_e6cb2"]
code = "shader_type spatial;
render_mode cull_disabled;

#include \"res://Common/ShaderIncludes/VertexWarble.gdshaderinc\"

uniform sampler2D albedo : filter_nearest;
uniform vec2 scroll_speed = vec2(0.0, 0.0);
uniform vec2 uv_scale = vec2(1.0, 1.0);

void vertex()
{
	VERTEX = warble_vertex(default_vertex_warble_settings(), VERTEX, VIEW_MATRIX, 10.0);
}

void fragment()
{
	vec2 uv = uv_scale * (UV + (scroll_speed * TIME));
	vec4 color = texture(albedo, uv);
	ALPHA = mix(color.a, 0.0, 1.0 - (UV.x * UV.x));
	ALBEDO = color.rgb;
}
"

