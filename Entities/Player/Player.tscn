[sub_resource type="GDScript" id="GDScript_cpnxc"]
script/source = "extends Node

var _startY : float = 0
var _maxHeight : float = 0
var _printedMaxHeight : bool = false

func _physics_process(_delta):
    var player : CharacterBody3D = get_parent()
    
    if (player.is_on_floor()):
        _startY = player.global_position.y
        _maxHeight = 0
        _printedMaxHeight = false
        return
    
    var height : float = player.global_position.y - _startY

    if (height >= _maxHeight):
        _maxHeight = height
    elif (!_printedMaxHeight):
        _printedMaxHeight = true
        print(_maxHeight)
        
"

