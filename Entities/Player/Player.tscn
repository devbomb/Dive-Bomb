[sub_resource type="GDScript" id="GDScript_h6pxy"]
script/source = "extends GridContainer

func _physics_process(_delta: float) -> void:
	visible = $'/root/UserSettings'.Instance().ShowPlayerVelocityStats
	
	if !visible:
		return
	
	var player: CharacterBody3D = owner
	$Velocity.text = str(player.velocity)
	$LocalVelocity.text = str(player.LocalVelocity)
	$LastPlatformVelocity.text = str(player.LastPlatformVelocity)
	$CurrentPlatformVelocity.text = str(player.get_platform_velocity())
	$OnWall.text = str(player.is_on_wall())
	$OnFloor.text = str(player.is_on_floor())
"

