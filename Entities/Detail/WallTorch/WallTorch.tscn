[sub_resource type="GDScript" id="GDScript_seutu"]
script/source = "@tool
extends Node3D

@export var energy: float = 1

func _ready():
	# So I don't need to enable editable-children
	%Model/Flame.layers = 2
	%Model/Flame.cast_shadow = false
	%WorldLight.light_energy = energy
	
	if (!Engine.is_editor_hint()):
		snap_to_wall()

func snap_to_wall():
	%RayCast3D.force_raycast_update()

	if (!%RayCast3D.is_colliding()):
		return

	var normal = %RayCast3D.get_collision_normal()
	var point = %RayCast3D.get_collision_point()
	look_at_from_position(point, point + normal)
	global_position += normal * 0.5
	global_rotation_degrees.y -= 90
"

