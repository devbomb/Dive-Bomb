[gd_resource type="ShaderMaterial" load_steps=6 format=3 uid="uid://wlu2q001eekk"]

[sub_resource type="Shader" id="Shader_xq3oj"]
code = "shader_type spatial;
render_mode diffuse_lambert_wrap;

uniform vec3 color : source_color;

uniform sampler2D noise_a : hint_normal;
uniform sampler2D noise_b : hint_normal;

uniform float scale_a = 0.01;
uniform float scale_b = 0.01;

const float time_scale_a = 1.0;
const float time_scale_b = 1.0;

void fragment() 
{
	vec2 offset_a = time_scale_a * vec2(TIME, TIME);
	vec2 offset_b = time_scale_b * vec2(-TIME, -TIME);
	
	METALLIC = 1.0;
	SPECULAR = 0.0;
	ROUGHNESS = 0.0;
	ALBEDO = color.rgb;
	NORMAL_MAP = mix(
		texture(noise_a, scale_a * (UV + offset_a)).xyz,
		texture(noise_b, scale_b * (UV + offset_b)).xyz,
		0.5
	);
}
"

