[gd_resource type="ShaderMaterial" load_steps=12 format=3 uid="uid://b5a214apdag3m"]

[sub_resource type="Shader" id="Shader_xq3oj"]
code = "shader_type spatial;
render_mode diffuse_lambert_wrap;

uniform sampler2D albedo_a : filter_nearest;
uniform sampler2D albedo_b : filter_nearest;

uniform sampler2D normal_a : hint_normal;
uniform sampler2D normal_b : hint_normal;

uniform float scale_albedo = 0.05;
uniform float scale_normal_a = 0.01;
uniform float scale_normal_b = 0.01;

const float time_scale_albedo_a = 20.0;
const float time_scale_albedo_b = 12.0;
const float time_scale_normal_a = 5.0;
const float time_scale_normal_b = 5.0;

void fragment() 
{
	vec2 offset_normal_a = time_scale_normal_a * vec2(TIME, TIME);
	vec2 offset_normal_b = time_scale_normal_b * vec2(-TIME, -TIME);
	
	vec2 offset_albedo_a = time_scale_albedo_a * vec2(0, -TIME);
	vec2 offset_albedo_b = time_scale_albedo_b * vec2(0, -TIME);
	
	vec3 albedo_a_color = texture(albedo_a, scale_albedo * (UV + offset_albedo_a)).xyz;
	vec3 albedo_b_color = texture(albedo_b, scale_albedo * (UV + offset_albedo_b)).xyz;
	
	METALLIC = 0.5;
	SPECULAR = 0.0;
	ROUGHNESS = 0.99;
	ALBEDO = mix(albedo_a_color, albedo_b_color, 0.5);
	NORMAL_MAP = mix(
		texture(normal_a, scale_normal_a * (UV + offset_normal_a)).xyz,
		texture(normal_b, scale_normal_b * (UV + offset_normal_b)).xyz,
		0.5
	);
}
"

