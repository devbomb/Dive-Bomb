[sub_resource type="GDScript" id="GDScript_x75wr"]
script/source = "extends Label

func _ready():
	SignalBus.connect(\"LevelReset\", _reset)
	_reset()

func _reset():
	visible = false

func _physics_process(_delta: float) -> void:
	if (!visible && _is_player_in_trigger()):
		visible = true

func _is_player_in_trigger() -> bool:
	return %PlayerDetector.get_overlapping_bodies().size() > 0
"

[sub_resource type="GDScript" id="GDScript_ida8r"]
script/source = "extends Label

func _ready():
	SignalBus.connect(\"LevelReset\", _reset)
	_reset()

func _reset():
	visible = false

func _physics_process(_delta: float) -> void:
	if (!visible && _is_player_in_trigger()):
		visible = true

func _is_player_in_trigger() -> bool:
	return Area3DSafetyTimer.GetOverlappingBodies(%PlayerDetector, 2).size() > 0
"

