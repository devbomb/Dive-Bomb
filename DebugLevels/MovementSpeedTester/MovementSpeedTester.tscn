[sub_resource type="Shader" id="Shader_yarhr"]
code = "shader_type spatial;
render_mode
	world_vertex_coords,
	cull_disabled;

uniform sampler2D albedo_texture : filter_nearest;
uniform sampler2D alpha_texture : filter_linear;

const float depth_offset = -1.0;
const float falloff_distance = 30.0;
const float power = 2.0;

void fragment()
{
	vec2 uv_world = (INV_VIEW_MATRIX * vec4(VERTEX, 1.0)).xz;
	ALBEDO = texture(albedo_texture, uv_world / 100.0).rgb;
	
	vec3 vertex_flat = VERTEX;
	vertex_flat.y = 0.0;
	float depth = length(vertex_flat) + depth_offset;
	
	float t = clamp(depth / falloff_distance, 0.0, 1.0);
	float alpha = 1.0 - pow(t, power);
	
	if (alpha < texture(alpha_texture, uv_world * 0.01).r)
		discard;
}
"

