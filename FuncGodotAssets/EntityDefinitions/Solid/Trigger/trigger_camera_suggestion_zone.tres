[ext_resource type="Script" uid="uid://g1sj4robijs3" path="res://Entities/Trigger/CameraSuggestionZone.cs" id="2_bent3"]

[resource]
script = ExtResource("1_2n3s0")
build_visuals = false
script_class = ExtResource("2_bent3")
classname = "trigger_camera_suggestion_zone"
description = "\"Suggests\" a camera angle when the player enters it.  The camera will move to the suggested angle, but there is nothing stopping the player from readjusting it back to their preferred angle."
class_properties = {
"DirectionMarkerId": "",
"SuggestedDistance": 6.0,
"SuggestedPitchDeg": 0.0,
"SuggestedYawDeg": 0.0
}
class_property_descriptions = {
"DirectionMarkerId": "If provided, it will use the rotation of a NamedMarker3D with this id, rather than SuggestedPitchDeg and SuggestedYawDeg.",
"SuggestedDistance": "How far away the camera is from the focal point",
"SuggestedPitchDeg": "The camera's pitch in degrees.  Not used if DirectionMarkerId is provided.",
"SuggestedYawDeg": "The camera's yaw in degrees.  Not used if DirectionMarkerId is provided."
}
auto_apply_to_matching_node_properties = true
node_class = "Area3D"
metadata/_custom_type_script = "uid://ctv13qfisgfqg"
