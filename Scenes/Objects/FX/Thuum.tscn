code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_disabled, diffuse_lambert, specular_schlick_ggx, unshaded;

uniform float TimeScale = 1.0;
uniform sampler2D tex_frg_2 : source_color;
uniform vec4 FlameColor : source_color = vec4(1.000000, 1.000000, 1.000000, 1.000000);
uniform float CutoffPercentage : hint_range(0.0, 1.0) = 0.5;



void fragment() {
// Input:3
	vec2 n_out3p0 = UV;


// Input:5
	float n_out5p0 = TIME;


// FloatParameter:12
	float n_out12p0 = TimeScale;


// FloatOp:11
	float n_out11p0 = n_out5p0 * n_out12p0;


// VectorCompose:6
	float n_in6p0 = 0.00000;
	vec2 n_out6p0 = vec2(n_in6p0, n_out11p0);


// VectorOp:4
	vec2 n_out4p0 = n_out3p0 - n_out6p0;


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, n_out4p0);


// ColorParameter:15
	vec4 n_out15p0 = FlameColor;


// VectorOp:14
	vec4 n_out14p0 = n_out2p0 * n_out15p0;
	float n_out14p1 = n_out14p0.r;
	float n_out14p2 = n_out14p0.g;
	float n_out14p3 = n_out14p0.b;
	float n_out14p4 = n_out14p0.a;


// Input:10
	vec2 n_out10p0 = UV;
	float n_out10p2 = n_out10p0.g;


// FloatParameter:13
	float n_out13p0 = CutoffPercentage;


	float n_out17p0;
// Remap:17
	float n_in17p1 = 0.00000;
	float n_in17p4 = 0.00000;
	{
		float __input_range = n_out13p0 - n_in17p1;
		float __output_range = n_in17p4 - n_out14p4;
		n_out17p0 = n_out14p4 + __output_range * ((n_out10p2 - n_in17p1) / __input_range);
	}


// Clamp:18
	float n_in18p1 = 0.00000;
	float n_in18p2 = 1.00000;
	float n_out18p0 = clamp(n_out17p0, n_in18p1, n_in18p2);


// VectorCompose:16
	vec4 n_out16p0 = vec4(n_out14p1, n_out14p2, n_out14p3, n_out18p0);
	float n_out16p4 = n_out16p0.a;


// Output:0
	ALBEDO = vec3(n_out16p0.xyz);
	ALPHA = n_out16p4;


}
"
