[sub_resource type="GDScript" id="GDScript_j3l7e"]
script/source = "@tool
extends Node3D

@export var diameter: float = 1:
	get: return _diameter
	set(value):
		_diameter = value
		_update_dimensions()
var _diameter: float = 1

@export var max_height: float = 100:
	get: return _max_height
	set(value):
		_max_height = value
		_update_dimensions()
var _max_height: float = 100

@export var height_margin: float = 0.25:
	get: return _height_margin
	set(value):
		_height_margin = value
		_update_dimensions()
var _height_margin: float = 0.25

func _enter_tree():
	_update_dimensions()

func _update_dimensions():

	if (Engine.is_editor_hint() && owner == null):
		print(\"No, I won't edit myself in my own scene\")
		return
	
	$Decal.size = Vector3(_diameter, max_height, _diameter)
	$Decal.position.y = -max_height / 2
	$Decal.position.y += height_margin
"

