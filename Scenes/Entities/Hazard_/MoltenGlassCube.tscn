[sub_resource type="GDScript" id="GDScript_kkmwj"]
script/source = "@tool
extends MeshInstance3D

func _ready():
	# Need to connect this via code because connecting it through the editor
	# produces an error saying that the signal has already been connected to
	# this method.  Sounds like a Godot bug.
	if (!get_parent().is_connected(\"ready\", _on_parent_ready)):
		get_parent().connect(\"ready\", _on_parent_ready)
	
	if (!get_parent().is_connected(\"tree_entered\", _on_parent_ready)):
		get_parent().connect(\"tree_entered\", _on_parent_ready)

func _on_parent_ready():
	for child in get_parent().get_children():
		if child != self && child is MeshInstance3D:
			var aabb: AABB = child.get_aabb()
			position = aabb.get_center()
			scale = aabb.size
			child.visible = false
"

[node name="MoltenGlassCube" type="Area3D"]
