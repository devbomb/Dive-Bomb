		"path" : "TrenchbroomEntityModels/Basket.obj",
		"scale" : 0.25
	})
	= Basket [
		GemColor(choices): "GemColor" : 1 = [
			1: "Red"
			2: "Green"
			5: "Purple"
			10: "Yellow"
			25: "Magenta"
		]
	]