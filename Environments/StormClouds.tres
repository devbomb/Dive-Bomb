code = "shader_type sky;
uniform sampler2D tex_sky_3 : source_color;



void sky() {
// FloatConstant:15
	float n_out15p0 = 0.500000;


// Input:4
	vec2 n_out4p0 = SKY_COORDS;
	float n_out4p2 = n_out4p0.g;


// Texture2D:3
	vec4 n_out3p0 = texture(tex_sky_3, n_out4p0);


// FloatOp:8
	float n_out8p0 = n_out4p2 * n_out4p2;


// VectorOp:12
	vec4 n_out12p0 = n_out3p0 * vec4(n_out8p0);


// VectorOp:14
	vec4 n_out14p0 = vec4(n_out15p0) * n_out12p0;


// FloatConstant:18
	float n_out18p0 = 0.050000;


// ColorConstant:11
	vec4 n_out11p0 = vec4(1.000000, 1.000000, 1.000000, 1.000000);


// VectorOp:16
	vec4 n_out16p0 = vec4(n_out18p0) * n_out11p0;


// ColorOp:19
	vec3 n_out19p0 = vec3(1.0) - (vec3(1.0) - vec3(n_out14p0.xyz)) * (vec3(1.0) - vec3(n_out16p0.xyz));


// Output:0
	COLOR = n_out19p0;


}
"
