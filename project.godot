[layer_names]

3d_render/layer_1="Default"
3d_render/layer_2="VisibleInPortals"
3d_render/layer_3="WorldPortal"
3d_render/layer_4="ReceiveDecals"
3d_physics/layer_1="Default"
3d_physics/layer_2="ObstructsCamera"
3d_physics/layer_3="Gems"
3d_physics/layer_4="Player"

[physics]

common/physics_jitter_fix=0.0
3d/physics_engine="Jolt Physics"
jolt_physics_3d/simulation/areas_detect_static_bodies=true

[shader_globals]

UNPAUSED_TIME={
"type": "float",
"value": 0.0
}
