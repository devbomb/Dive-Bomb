; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Fast Dragon"
run/main_scene="res://Screens/TitleScreen/TitleScreen.tscn"
config/features=PackedStringArray("4.5", "C#", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Log="*res://Singletons/Log.cs"
SaveFileManager="*res://Singletons/SaveFileManager.cs"
SignalBus="*res://Singletons/SignalBus.cs"
Area3DSafetyTimer="*res://Singletons/Area3DSafetyTimer.cs"
GemFactory="*res://Singletons/GemFactory/GemFactory.tscn"
LevelTransitionManager="*res://Singletons/LevelTransitionManager/LevelTransitionManager.tscn"
UserSettings="*res://Common/Scripts/Services/UserSettingsGDScriptAdaptor.cs"
PhysicsInterpolatorSingleton="*res://Common/Scripts/PhysicsInterpolation/PhysicsInterpolatorSingleton.cs"
HitStopManager="*res://Singletons/HitStopManager.cs"
ShaderUnpausedTimer="res://Singletons/ShaderUnpausedTimer.gd"
ControllerIcons="*res://addons/controller_icons/ControllerIcons.cs"

[dotnet]

project/assembly_name="Fast Dragon"

[editor]

import/use_multiple_threads=false

[editor_plugins]

enabled=PackedStringArray("res://addons/FuncGodotMapImporter/plugin.cfg", "res://addons/MiscTools/plugin.cfg", "res://addons/controller_icons/plugin.cfg", "res://addons/func_godot/plugin.cfg")

[func_godot]

default_map_settings="uid://pgh6d0v7fyip"
default_inverse_scale_factor=16.0
model_point_class_save_path="TrenchbroomEntityModels"

[global_group]

PhysicsInterpolated=""
UnsafeGround="If a collision object is tagged with this, it is not considered \"safe\" ground.  The player will not update its \"last safe ground\" position when standing on it."

