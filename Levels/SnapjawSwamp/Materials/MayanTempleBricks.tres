[sub_resource type="Shader" id="Shader_skod2"]
code = "shader_type spatial;
render_mode
	blend_mix,
	depth_draw_opaque,
	cull_back,
	diffuse_burley,
	specular_schlick_ggx;

#include \"res://Common/ShaderIncludes/Noise.gdshaderinc\"

uniform vec4 albedo : source_color;
uniform sampler2D texture_albedo : source_color, filter_nearest_mipmap, repeat_enable;
uniform ivec2 albedo_texture_size;

const float displacement_strength = 0.6;
const vec2 displacement_frequency = vec2(1.0, 2.0);

vec2 nearest_pixel(vec2 uv, float pixel_size)
{
	vec2 scaled = uv / pixel_size;
	vec2 rounded = vec2(floor(scaled.x), floor(scaled.y));
	return pixel_size * rounded;
}

vec2 displacement_noise(vec2 uv)
{
	uv *= displacement_frequency;
	uv = nearest_pixel(uv, 0.1);
	return vec2
	(
		perlin12(uv),
		perlin12(uv)
	);
}

void fragment()
{
	vec2 base_uv = UV;
	base_uv += displacement_strength * displacement_noise(base_uv);

	vec4 albedo_tex = texture(texture_albedo, base_uv);
	ALBEDO = albedo.rgb * albedo_tex.rgb;
}"

[resource]
