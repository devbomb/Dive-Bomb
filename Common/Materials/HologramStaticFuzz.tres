[gd_resource type="ShaderMaterial" load_steps=2 format=3 uid="uid://mvm170lhls8a"]

[sub_resource type="Shader" id="Shader_pht2m"]
code = "shader_type spatial;
#include \"res://Common/ShaderIncludes/FloatHashes.gdshaderinc\"

void fragment()
{
	ALBEDO = vec3(0.0, 0.0, 0.0);
	
	vec2 hash_uv = floor(UV * 100.0) / 100.0;
	float hash_time = floor(TIME * 20.0) / 20.0;
	float noise = (0.7 * hash12(fract(hash_uv * hash_time))) + (0.3 * hash12(UV * 0.1 * hash_time));
	ALPHA = mix(0.0, 0.6, noise);
}
"

[resource]
render_priority = 0
shader = SubResource("Shader_pht2m")
